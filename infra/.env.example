# Copy to .env and adjust for your environment.
# docker compose reads this file automatically.

# --- PostgreSQL ---
CONDDO_DB_NAME=conddo
# Owner / migration role (Flyway connects as this).
CONDDO_DB_OWNER=conddo_owner
CONDDO_DB_OWNER_PASSWORD=owner_password
# Runtime application role (the Spring app connects as this; RLS applies).
CONDDO_DB_APP_USER=app_user
CONDDO_DB_APP_PASSWORD=app_password
CONDDO_DB_PORT=5432

# --- Redis ---
CONDDO_REDIS_PORT=6379

# --- MinIO ---
CONDDO_MINIO_USER=conddo
CONDDO_MINIO_PASSWORD=conddo_secret_change_me
CONDDO_MINIO_PORT=9000
CONDDO_MINIO_CONSOLE_PORT=9001
