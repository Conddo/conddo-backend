<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.conddo</groupId>
        <artifactId>conddo-parent</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>conddo-core</artifactId>
    <name>Conddo.io Core Platform</name>
    <description>Multi-tenancy, security primitives, persistence, shared domain</description>

    <dependencies>
        <!-- Persistence + JPA entities and repositories -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>
        <!-- Redis pub/sub for live stock events (Pharmacy Spec v2 §12A).
             Auto-config only fires when a connection is configured; the
             StockEventPublisher fails-safe when the bean is absent. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-redis</artifactId>
        </dependency>
        <!-- Web: needed for the tenant servlet filter + shared web types -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <!-- Bean Validation on DTOs / entities -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>
        <!-- JWT (JOSE): RSA-signed access tokens. Pulls spring-security-core +
             spring-security-crypto (BCrypt) transitively, WITHOUT triggering
             Spring Boot's web-security auto-config lockdown — that arrives with
             the resource server (conddo-api) when the auth filter chain is wired. -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-oauth2-jose</artifactId>
        </dependency>
        <!-- Google ID-token verification (Slice H / §1a). google-api-client
             brings GoogleIdToken + GoogleIdTokenVerifier + JWKS caching. -->
        <dependency>
            <groupId>com.google.api-client</groupId>
            <artifactId>google-api-client</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
